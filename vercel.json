{
    "builds": [
        {
            "src": "fastapi-application/main.py",
            "use": "@vercel/python",
            "config": { "maxLambdaSize": "50mb" }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "fastapi-application/main.py"
        }
    ]
}
